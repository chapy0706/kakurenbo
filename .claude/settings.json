{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"sandbox": {
		"enabled": true,
		"allowUnsandboxedCommands": false,
		"filesystem": {
			"denyRead": [
				"~/.aws/credentials",
				"~/.ssh",
				"~/.gnupg",
				"~/.npmrc",
				"~/.git-credentials"
			]
		},
		"network": {
			"allowedDomains": [
				"github.com",
				"api.github.com",
				"codeload.github.com",
				"*.githubusercontent.com",
				"*.npmjs.org",
				"registry.yarnpkg.com",
				"nodejs.org",
				"downloads.nodejs.org"
			]
		}
	},
	"permissions": {
		"allow": [
			"Bash(pnpm *)",
			"Bash(make *)",
			"Bash(git status)",
			"Bash(git diff *)",
			"Bash(git log *)",
			"Bash(rg *)",
			"Bash(grep *)",
			"Bash(ls *)",
			"Bash(tree *)",
			"Bash(cat *)"
		],
		"ask": [
			"Bash(git commit *)",
			"Bash(pnpm add *)",
			"Bash(pnpm dlx *)",
			"Bash(docker *)"
		],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(git push *)",
			"Bash(git reset --hard *)",
			"Bash(curl *)",
			"Bash(wget *)",
			"Read(**/.env*)",
			"Read(**/secrets/**)",
			"Bash(chmod 777 *)",
			"Bash(sudo *)",
			"Bash(dd *)",
			"Read(**/*.pem)",
			"Read(**/*.key)",
			"Read(**/.npmrc)",
			"Read(**/.git-credentials)"
		],
		"disableBypassPermissionsMode": "disable",
		"defaultMode": "default"
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{ "type": "command", "command": ".claude/hooks/block-dangerous.sh" }
				]
			},
			{
				"matcher": "Read",
				"hooks": [
					{ "type": "command", "command": ".claude/hooks/protect-secrets.sh" }
				]
			}
		]
	}
}
